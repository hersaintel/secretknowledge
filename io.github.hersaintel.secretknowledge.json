{
  "app-id": "io.github.hersaintel.secretknowledge",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "secret-knowledge",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications",
    "--env=GI_TYPELIB_PATH=/app/lib/girepository-1.0:/usr/lib/girepository-1.0",
    "--env=LD_LIBRARY_PATH=/app/lib:/usr/lib"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "pygobject",
      "buildsystem": "meson",
      "config-opts": [
        "--buildtype=release"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/pygobject/3.46/pygobject-3.46.0.tar.xz",
          "sha256": "426008b2dad548c9af1c7b03b59df0440fde5c33f38fb5406b103a43d653cafc"
        }
      ],
      "build-options": {
        "env": {
          "PYTHON": "/usr/bin/python3"
        }
      }
    },
    {
      "name": "secret-knowledge",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 build-aux/secret-knowledge.sh /app/bin/secret-knowledge",
        "install -Dm644 src/main.py /app/share/secret-knowledge/src/main.py",
        "install -Dm644 data/secret-knowledge-v2.html /app/share/secret-knowledge/data/secret-knowledge-v2.html",
        "install -Dm644 data/io.github.hersaintel.secretknowledge.desktop /app/share/applications/io.github.hersaintel.secretknowledge.desktop",
        "install -Dm644 data/io.github.hersaintel.secretknowledge.metainfo.xml /app/share/metainfo/io.github.hersaintel.secretknowledge.metainfo.xml",
        "install -Dm644 icons/hicolor/scalable/apps/io.github.hersaintel.secretknowledge.svg /app/share/icons/hicolor/scalable/apps/io.github.hersaintel.secretknowledge.svg",
        "install -Dm644 icons/hicolor/symbolic/apps/io.github.hersaintel.secretknowledge-symbolic.svg /app/share/icons/hicolor/symbolic/apps/io.github.hersaintel.secretknowledge-symbolic.svg",
        "install -Dm644 icons/hicolor/16x16/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/16x16/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/24x24/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/24x24/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/32x32/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/32x32/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/48x48/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/48x48/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/64x64/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/64x64/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/128x128/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/128x128/apps/io.github.hersaintel.secretknowledge.png",
        "install -Dm644 icons/hicolor/256x256/apps/io.github.hersaintel.secretknowledge.png /app/share/icons/hicolor/256x256/apps/io.github.hersaintel.secretknowledge.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
