{
  "app-id": "io.hersaintel.secretknowledge",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "secret-knowledge",
  "finish-args": [
    "--share=ipc",
    "--share=network",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "secret-knowledge",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/hersaintel/secretknowledge.git",
          "tag": "v2.0.0",
          "commit": "02b21f48b8bccb801c53dd4b065845de861dde26"
        }
      ]
    }
  ]
}
