<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.hersaintel.secretknowledge</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Book of Secret Knowledge</name>
  <summary>Offline browser for 1,657 security tools and resources</summary>

  <description>
    <p>
      The Book of Secret Knowledge is a searchable offline reference for
      security professionals, penetration testers, sysadmins, and developers.
      Curated by Hersa, a cyber intelligence analyst, it provides instant
      access to 1,657 tools and resources across 12 categories.
    </p>
    <p>Features include:</p>
    <ul>
      <li>1,657 tools with full README documentation embedded offline</li>
      <li>Instant search across names, descriptions, and categories</li>
      <li>Coverage of CLI tools, pentesting, OSINT, AI security, cryptography, networking, and more</li>
      <li>Per-tool notes saved locally</li>
      <li>Bookmarks for quick access to favourite tools</li>
      <li>Live RSS feeds from top security blogs and channels</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.hersaintel.secretknowledge.desktop</launchable>

  <!-- URL must match the actual GitHub repo so the linter can reach it -->
  <url type="homepage">https://github.com/hersaintel/secret-knowledge-app</url>
  <url type="bugtracker">https://github.com/hersaintel/secret-knowledge-app/issues</url>

  <!-- Modern developer block (replaces deprecated developer_name tag) -->
  <developer id="io.hersaintel">
    <name>Hersa</name>
  </developer>

  <provides>
    <binary>secret-knowledge</binary>
  </provides>

  <releases>
    <release version="2.0.0" date="2026-06-02">
      <description>
        <p>Major update: expanded to 1,657 tools. Added AI security category,
        cloud security tools, hardware/embedded security, and new About panel
        with disclaimer and contact information.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/hersaintel/secret-knowledge-app/master/screenshots/screenshot-main.png</image>
      <caption>Main tool browser with search and category sidebar</caption>
    </screenshot>
  </screenshots>

  <categories>
    <category>Network</category>
    <category>Security</category>
    <category>Education</category>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>security</keyword>
    <keyword>hacking</keyword>
    <keyword>pentest</keyword>
    <keyword>osint</keyword>
    <keyword>sysadmin</keyword>
    <keyword>tools</keyword>
    <keyword>reference</keyword>
    <keyword>offline</keyword>
    <keyword>cryptography</keyword>
    <keyword>ai-security</keyword>
  </keywords>
</component>
