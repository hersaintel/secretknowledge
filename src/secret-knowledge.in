#!/usr/bin/env @PYTHON@

import os
import sys

# Set data directory based on install prefix
pkgdatadir = '@PKGDATADIR@'
os.environ.setdefault('SECRET_KNOWLEDGE_DATA', os.path.join(pkgdatadir, 'data'))

# Add the package to Python path
sys.path.insert(1, pkgdatadir)

# Handle D-Bus session bus for Flatpak
if 'DBUS_SESSION_BUS_ADDRESS' not in os.environ:
    import subprocess
    args = ['dbus-run-session', '@PYTHON@', '-m', 'secret-knowledge.main'] + sys.argv[1:]
    os.execvp('dbus-run-session', args)

from secret_knowledge import main
sys.exit(main.main())
